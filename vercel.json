{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/gemini/generate-post",
      "destination": "/api/gemini/generate-post.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/server.ts"
    },
    {
      "source": "/share/(.*)",
      "destination": "/api/server.ts"
    },
    {
      "source": "/((?!api|assets|favicon.ico|manifest.json|robots.txt|share).*)",
      "destination": "/index.html"
    }
  ]
}
